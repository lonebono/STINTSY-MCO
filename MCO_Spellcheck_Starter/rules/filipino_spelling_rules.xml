<?xml version="1.0" encoding="UTF-8"?>
<!--
  Draft rule file for MCO Filipino spell-checking rules.
  These rules target high-frequency nonstandard spellings in formal Filipino writing.
-->
<rules lang="tl" xsi:noNamespaceSchemaLocation="../rules.xsd" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">

  <category id="MCO_FILIPINO_SPELLING" name="Filipino Spelling (MCO)">

    <rule id="MCO_RULE_1_HINDE" name="hinde -> hindi (standard form)">
      <pattern>
        <token regexp="yes" case_sensitive="no">hinde</token>
      </pattern>
      <message>Sa pormal na baybay sa Filipino, gamitin ang "hindi".</message>
      <suggestion>hindi</suggestion>
      <short>Spelling</short>
      <example correction="hindi">Mali: <marker>hinde</marker> ako makakasama.</example>
      <example correction="hindi">Mali: <marker>Hinde</marker> pa tapos ang klase.</example>
      <example correction="hindi">Mali: <marker>hinde</marker> siya sumagot.</example>
      <example>Tama: hindi ako makakasama.</example>
      <example>Tama: Hindi pa tapos ang klase.</example>
      <example>Tama: hindi siya sumagot.</example>
    </rule>

    <rule id="MCO_RULE_2_KASE" name="kase -> kasi (standard form)">
      <pattern>
        <token regexp="yes" case_sensitive="no">kase</token>
      </pattern>
      <message>Sa pormal na baybay sa Filipino, gamitin ang "kasi".</message>
      <suggestion>kasi</suggestion>
      <short>Spelling</short>
      <example correction="kasi">Mali: Umalis ako <marker>kase</marker> umuulan.</example>
      <example correction="kasi">Mali: <marker>Kase</marker> sarado na ang tindahan.</example>
      <example correction="kasi">Mali: Late siya <marker>kase</marker> traffic.</example>
      <example>Tama: Umalis ako kasi umuulan.</example>
      <example>Tama: Kasi sarado na ang tindahan.</example>
      <example>Tama: Late siya kasi traffic.</example>
    </rule>

    <rule id="MCO_RULE_3_PEDE" name="pede -> puwede (standard form)">
      <pattern>
        <token regexp="yes" case_sensitive="no">pede</token>
        <exception case_sensitive="yes" regexp="yes">Pede|PEDE</exception>
      </pattern>
      <message>Sa pormal na baybay sa Filipino, gamitin ang "puwede".</message>
      <suggestion>puwede</suggestion>
      <short>Spelling</short>
      <example correction="puwede">Mali: <marker>pede</marker> bang pumasok?</example>
      <example correction="puwede">Mali: <marker>Pede</marker> po ba ito?</example>
      <example correction="puwede">Mali: <marker>pede</marker> na ba umalis?</example>
      <example>Tama: puwede bang pumasok?</example>
      <example>Tama: Puwede po ba ito?</example>
      <example>Tama: puwede na ba umalis?</example>
    </rule>

  </category>
</rules>
